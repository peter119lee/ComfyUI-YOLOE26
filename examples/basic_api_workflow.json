{
  "_readme": "NOTE: model_name uses '(downloadable)' label until ComfyUI is restarted after first download. The workflow will run successfully on first use — no restart needed before first run. After restart, the label changes to '(local)'.",
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "example.png"
    },
    "_meta": {
      "title": "Load Image"
    }
  },
  "2": {
    "class_type": "YOLOE26LoadModel",
    "inputs": {
      "model_name": "yoloe-26s-seg.pt (downloadable)",
      "device": "auto",
      "auto_download": true
    },
    "_meta": {
      "title": "YOLOE-26 Load Model"
    }
  },
  "3": {
    "class_type": "YOLOE26PromptSegment",
    "inputs": {
      "model": ["2", 0],
      "image": ["1", 0],
      "prompt": "person",
      "conf": 0.1,
      "iou": 0.7,
      "max_det": 300,
      "mask_threshold": 0.5,
      "imgsz": 640,
      "show_boxes": true,
      "show_labels": true,
      "show_conf": true,
      "show_masks": true
    },
    "_meta": {
      "title": "YOLOE-26 Prompt Segment"
    }
  },
  "4": {
    "class_type": "PreviewImage",
    "inputs": {
      "images": ["3", 0]
    },
    "_meta": {
      "title": "Preview Image"
    }
  }
}
